<Layout>
  <div class="pb-12 mt-5">   
    <div class="text-xl py-1">Hola 👋 Soy Brian!</div>
    
    <div class="text-3xl py-3 font-bold">Backend web developer</div>
    <div class="py-2">
      <text class="text-lg">
        Soy Desarrollador Web Backend con Python, creo aplicaciones web utilizando frameworks como Django, FastAPI y Flask.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://t.me/brianmrdev" target="_blank">
        Conectémonos!</a
      >
      <a
        href="mailto:brianmr1128@gmail.com"
        target="_blank"
        class="btn btn-outline ml-5"
      >
        Escríbeme</a
      >
    </div>    
  </div>
  <div>
    <div class="text-3xl w-full font-bold mb-2">Algunos de mis proyectos {"</>"}</div>
  </div>
  <HorizontalCard
      title="Sitio web de comercio electrónico"
      img="/Hostal-Manuel-Enrique.webp"
      desc="Sitio web de promoción y gestión de reservas de un Hostal, desarrollada en Python-Django. Integrada pasarela de pagos de Enzona."
      url_code=""
      url_live="https://www.hostalmanuelenrique.cu"
