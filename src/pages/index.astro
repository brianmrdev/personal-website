      url_live="https://www.climaig.cu"
      badge="Website"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
      title="Sistema de Gestión y Monitoreo de estudios diagnósticos del SARS-CoV-2."
      img="/pcr-app.webp"
      desc="El sistema desarrollado en Python/Django, protocoliza y automatiza el flujo de trabajo desde la toma de muestra hasta la notificación de resultado a las instituciones de Salud. Lo complementa un bot de Telegram para la consulta de resultados por la población."
      url_code=""
      url_live=""
      badge="Web Application"
    />

</Layout>
