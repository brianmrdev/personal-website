---
import Layout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<Layout>
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Portafolio de proyectos terminados {"</>"}</div>
  </div>


  <HorizontalCard
      title="Sitio web de agencia multiservicio entre Cuba y Brasil"
      img="/acem.webp"
      desc="Este emocionante proyecto implicó la creación de un sitio web para una agencia multiservicio que conecta a personas y negocios entre Cuba y Brasil. Desde el envío de remesas hasta la entrega de combos personalizados y el alquiler de taxis, la plataforma ofrece una amplia gama de servicios diseñados para satisfacer las necesidades únicas de la comunidad transfronteriza. Desarrollada en Python-Django"
      url_code=""
      url_live="https://www.acem.life/"
      badge="Website"
    />
    <div class="divider my-0"></div>
  <HorizontalCard
      title="Sitio web de envíos internacionales de contenedores"
      img="/LPG-TRANSIT-&-TRADE.webp"
      desc="En este proyecto, me sumergí en el mundo del transporte logístico para crear un sitio web que reflejara la eficiencia y la confiabilidad de los servicios de transporte de contenedores. Desarrollado en Wordpress, multilenguaje."
      url_code=""
      url_live="https://lpgtransit.com/"
      badge="Website"
    />
    <div class="divider my-0"></div>
  <HorizontalCard
      title="Sitio web de inmoviliaria"
      img="/ipropiertescv.webp"
      desc="Este proyecto implicó la creación de un sitio web moderno y funcional que reflejara la profesionalidad y la calidad de los servicios ofrecidos. Desarrollado en Wordpress, multilenguaje."
      url_code=""
      url_live="https://ipropertiescv.com/"
      badge="Website"
    />
    <div class="divider my-0"></div>
  <HorizontalCard
      title="Sitio web de Hostal en Cuba"
      img="/Hostal-Manuel-Enrique.webp"
      desc="Sitio web de promoción y gestión de reservas de un Hostal, desarrollada en Python-Django. Integrada pasarela de pagos de Enzona."
      url_code=""
      url_live="https://hostal.webdev.cu/"
      badge="Website"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
      title="Sitio web de Mipyme de Clima"
      img="/Clima-I&G.webp"
      desc="Plataforma de comercio electrónico de la Mipyme Clima I&G, desarrollada en Python-Django. Integrada pasarela de pagos de Enzona."
      url_code=""
      url_live="https://climaig.webdev.cu/"
      badge="Website"
    />
    <div class="divider my-0"></div>
    <HorizontalCard
      title="Sistema de Gestión y Monitoreo de estudios diagnósticos del SARS-CoV-2."
      img="/pcr-app.webp"
      desc="El sistema desarrollado en Python/Django, protocoliza y automatiza el flujo de trabajo desde la toma de muestra hasta la notificación de resultado a las instituciones de Salud. Lo complementa un bot de Telegram para la consulta de resultados por la población."
      url_code=""
      url_live=""
      badge="Web Application"
    />
</Layout>