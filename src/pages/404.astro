---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 — Página no encontrada | Brian Martínez"
  description="La página que buscas no existe."
>
  <main class="flex flex-col items-center justify-center min-h-[70vh] px-4 text-center">
    <p class="text-8xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-indigo-500 to-teal-400 mb-4">
      404
    </p>
    <h1 class="text-2xl font-semibold mb-3">Página no encontrada</h1>
    <p class="text-gray-400 max-w-md mb-8">
      La página que buscas no existe o fue movida. Vuelve al inicio y navega desde allí.
    </p>
    <a
      href="/"
      class="btn bg-blue-500 border-blue-500 text-white hover:bg-blue-400 hover:border-blue-400 rounded-3xl px-6 py-3"
    >
      Volver al inicio
    </a>
  </main>
</Layout>
