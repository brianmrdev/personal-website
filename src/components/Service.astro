---
const SERVICE = [
  {
    title: "Landing Pages y Sitios Web Corporativos",
    description:
      "Páginas de aterrizaje y sitios web profesionales enfocados en conversión y presencia de marca, adaptados a la identidad de cada empresa.",
    icon: "monitor",
  },
  {
    title: "Tiendas Virtuales",
    description:
      "Tiendas en línea con interfaces optimizadas para aumentar la conversión, integrando métodos de pago seguros y gestión de productos eficiente.",
    icon: "cart",
  },
  {
    title: "Aplicaciones Web a la Medida",
    description:
      "Aplicaciones web personalizadas con arquitecturas escalables que garantizan rendimiento óptimo y seguridad.",
    icon: "code",
  },
  {
    title: "Infraestructura y Administración Cloud",
    description:
      "Gestión de servidores virtuales y entornos en la nube con Docker y Kubernetes, asegurando alta disponibilidad y escalabilidad.",
    icon: "server",
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-6xl mx-auto">
  {
    SERVICE.map((service, i) => (
      <div
        data-animate="fade-up"
        data-animate-delay={`${i * 0.1}s`}
        class="service-card group rounded-2xl border border-gray-700/50 bg-base-300/30 p-6 transition-all duration-300 hover:border-blue-400/50 hover:bg-base-300/60"
      >
        <div class="mb-4 flex size-12 items-center justify-center rounded-xl bg-blue-400/10 text-blue-400 transition-colors duration-300 group-hover:bg-blue-400/20">
          {service.icon === "monitor" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
            </svg>
          )}
          {service.icon === "cart" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
            </svg>
          )}
          {service.icon === "code" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
            </svg>
          )}
          {service.icon === "server" && (
            <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
            </svg>
          )}
        </div>
        <h3 class="text-lg font-semibold mb-2">{service.title}</h3>
        <p class="text-gray-400 text-sm leading-relaxed">{service.description}</p>
      </div>
    ))
  }
</div>
