---
interface Props {
  title: string;
  description: string;
  date: string;
  isCurrent?: boolean;
  tags?: string[];
  animateDelay?: string;
}

const { title, description, date, isCurrent, tags = [], animateDelay } = Astro.props;
---

<span
  class="absolute flex items-center justify-center w-6 h-6 rounded-full -start-3 bg-blue-900"
>
  <svg
    class="w-2.5 h-2.5 text-blue-300"
    aria-hidden="true"
    xmlns="http://www.w3.org/2000/svg"
    fill="currentColor"
    viewBox="0 0 20 20"
  >
    <path
      d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"
    ></path>
  </svg>
</span>
<div data-animate="fade-left" data-animate-delay={animateDelay}>
<h3
  class="flex flex-wrap items-center mb-1 text-xl font-medium"
>
  {title}
  {
    isCurrent && (
      <span class="badge-actual bg-blue-900 text-blue-300 text-sm font-medium px-2.5 py-0.5 rounded ms-3">
        Actual
      </span>
    )
  }
</h3>
<time
  class="block mb-2 text-sm font-normal leading-none text-gray-400 dark:text-gray-400"
  >{date}</time
>
<p class="mb-3 text-base font-normal text-gray-500 dark:text-gray-300">
  {description}
</p>
{tags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-700/50 text-gray-300 border border-gray-600/50">
        {tag}
      </span>
    ))}
  </div>
)}
</div>

<style>
  .badge-actual {
    animation: pulse-badge 2s ease-in-out infinite;
  }

  @keyframes pulse-badge {
    0%, 100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(96, 165, 250, 0.4);
    }
    50% {
      opacity: 0.85;
      box-shadow: 0 0 0 6px rgba(96, 165, 250, 0);
    }
  }
</style>
